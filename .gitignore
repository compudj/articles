# LaTeX build artifacts
*.aux
*.log
*.out
*.toc
*.blg
*.synctex.gz
*.fdb_latexmk
*.fls

# Build-mode tracking, generated by common/paper.mk (see the mode.txt rule).
draft.flag
mode.txt

# The .bbl is deliberately NOT ignored: it ships with the arXiv submission.
# See common/paper.mk.

# arXiv staging
arxiv-stage/
*-arxiv.tar.gz

# Per-paper scratchpad: extracted primary-source texts (SCX, Shenandoah,
# reuse-don't-recycle, ...) kept locally for exact quotes when drafting Related
# Work. Third-party paper text -- never vendored into the repo.
scratchpad/
*/scratchpad/

# Built PDFs are generated; regenerate with `make`.
*.pdf
