% verified: dblp.org/rec/conf/asplos/KimMKRM19
% The multi-versioned successor to RLU, addressing RLU's synchronous writeback:
% RLU quiesces writers to reclaim old versions, which serialises the write side
% under churn. MV-RLU keeps multiple versions and reclaims them concurrently.
%
% Relevance: RLU and MV-RLU attack the same problem as this engine -- atomic
% multi-pointer update with concurrent readers -- and both provide a COHERENT
% SNAPSHOT, which is strictly stronger than what a pseudo-transaction gives.
% They buy it the same way existence structures do: per-object metadata (the RLU
% header) plus a check on every rlu_dereference(). Any comparison against RLU is
% therefore across guarantee classes and must say so in the text; the comparison
% against existence structures is class-matched and needs no such asterisk.
% MV-RLU specifically is the arm a reviewer will ask about, since it relieves
% precisely the writeback bottleneck that our RLU-defer numbers exercise.
@inproceedings{kim2019mvrlu,
  author       = {Jaeho Kim and
                  Ajit Mathew and
                  Sanidhya Kashyap and
                  Madhava Krishnan Ramanathan and
                  Changwoo Min},
  editor       = {Iris Bahar and
                  Maurice Herlihy and
                  Emmett Witchel and
                  Alvin R. Lebeck},
  title        = {{MV-RLU:} Scaling Read-Log-Update with Multi-Versioning},
  booktitle    = {Proceedings of the Twenty-Fourth International Conference on Architectural
                  Support for Programming Languages and Operating Systems, {ASPLOS}
                  2019, Providence, RI, USA, April 13-17, 2019},
  pages        = {779--792},
  publisher    = {{ACM}},
  year         = {2019},
  doi          = {10.1145/3297858.3304040},
  url          = {https://doi.org/10.1145/3297858.3304040}
}



